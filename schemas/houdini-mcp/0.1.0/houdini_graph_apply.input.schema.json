{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hia:houdini-mcp:0.1.0:houdini_graph_apply:input",
  "title": "houdini_graph_apply input",
  "description": "Apply one already validated generic declarative graph as a new HIA-owned container. Approval is verified outside untrusted MCP arguments and binds the complete canonical graph, expected session, revision, target, and digest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "thread_id",
    "turn_id",
    "hip_session_id",
    "expected_hip_fingerprint",
    "base_scene_revision",
    "idempotency_key",
    "deadline_ms",
    "permission_level",
    "graph",
    "canonical_graph_digest"
  ],
  "properties": {
    "request_id": {
      "$ref": "#/$defs/identifier"
    },
    "thread_id": {
      "$ref": "#/$defs/identifier"
    },
    "turn_id": {
      "$ref": "#/$defs/identifier"
    },
    "hip_session_id": {
      "$ref": "#/$defs/identifier"
    },
    "expected_hip_fingerprint": {
      "$ref": "#/$defs/fingerprint"
    },
    "base_scene_revision": {
      "$ref": "#/$defs/sceneRevision"
    },
    "idempotency_key": {
      "$ref": "#/$defs/idempotencyKey"
    },
    "deadline_ms": {
      "$ref": "#/$defs/deadlineMs"
    },
    "permission_level": {
      "const": "scene_write"
    },
    "graph": {
      "$ref": "#/$defs/graph"
    },
    "canonical_graph_digest": {
      "$ref": "#/$defs/digest"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{15,127}$"
    },
    "sceneRevision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "deadlineMs": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    },
    "fingerprint": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Fa-f0-9]{16,128}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "parameterName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z][A-Za-z0-9_]{0,127}$"
    },
    "localId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "nameHint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$"
    },
    "floatValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "float"
        },
        "value": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        }
      }
    },
    "intValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "int"
        },
        "value": {
          "type": "integer",
          "minimum": -2147483648,
          "maximum": 2147483647
        }
      }
    },
    "boolValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "bool"
        },
        "value": {
          "type": "boolean"
        }
      }
    },
    "stringValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "string"
        },
        "value": {
          "type": "string",
          "maxLength": 4096,
          "pattern": "^[^\\u0000-\\u001F\\u007F]*$"
        }
      }
    },
    "floatTuple": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "items_type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "tuple"
        },
        "items_type": {
          "const": "float"
        },
        "value": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "number",
            "minimum": -1000000000,
            "maximum": 1000000000
          }
        }
      }
    },
    "intTuple": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "items_type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "tuple"
        },
        "items_type": {
          "const": "int"
        },
        "value": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
          }
        }
      }
    },
    "boolTuple": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "items_type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "tuple"
        },
        "items_type": {
          "const": "bool"
        },
        "value": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "boolean"
          }
        }
      }
    },
    "stringTuple": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "items_type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "tuple"
        },
        "items_type": {
          "const": "string"
        },
        "value": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "string",
            "maxLength": 4096,
            "pattern": "^[^\\u0000-\\u001F\\u007F]*$"
          }
        }
      }
    },
    "typedValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/floatValue"
        },
        {
          "$ref": "#/$defs/intValue"
        },
        {
          "$ref": "#/$defs/boolValue"
        },
        {
          "$ref": "#/$defs/stringValue"
        },
        {
          "$ref": "#/$defs/floatTuple"
        },
        {
          "$ref": "#/$defs/intTuple"
        },
        {
          "$ref": "#/$defs/boolTuple"
        },
        {
          "$ref": "#/$defs/stringTuple"
        }
      ]
    },
    "nodeType": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "context",
            "name"
          ],
          "properties": {
            "context": {
              "const": "Sop"
            },
            "name": {
              "type": "string",
              "enum": [
                "box",
                "transform",
                "merge",
                "null"
              ]
            }
          }
        }
      ]
    },
    "graphTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_path",
        "root_local_id",
        "root_type",
        "name_hint",
        "ownership"
      ],
      "properties": {
        "parent_path": {
          "const": "/obj"
        },
        "root_local_id": {
          "const": "root"
        },
        "root_type": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "context",
            "name"
          ],
          "properties": {
            "context": {
              "const": "Object"
            },
            "name": {
              "const": "geo"
            }
          }
        },
        "name_hint": {
          "type": "string",
          "minLength": 11,
          "maxLength": 74,
          "pattern": "^HIA_Graph_[A-Za-z0-9][A-Za-z0-9_]{0,63}$"
        },
        "ownership": {
          "const": "hia_owned_new"
        }
      }
    },
    "parameterAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/parameterName"
        },
        "value": {
          "$ref": "#/$defs/typedValue"
        }
      }
    },
    "graphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name_hint",
        "parent",
        "parameters",
        "flags"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "type": {
          "$ref": "#/$defs/nodeType"
        },
        "name_hint": {
          "$ref": "#/$defs/nameHint"
        },
        "parent": {
          "const": "root"
        },
        "parameters": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/parameterAssignment"
          }
        },
        "flags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "display",
            "render"
          ],
          "properties": {
            "display": {
              "type": "boolean"
            },
            "render": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "sourceEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node",
        "output"
      ],
      "properties": {
        "node": {
          "$ref": "#/$defs/localId"
        },
        "output": {
          "type": "integer",
          "minimum": 0,
          "maximum": 63
        }
      }
    },
    "destinationEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node",
        "input"
      ],
      "properties": {
        "node": {
          "$ref": "#/$defs/localId"
        },
        "input": {
          "type": "integer",
          "minimum": 0,
          "maximum": 63
        }
      }
    },
    "connection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "destination"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/sourceEndpoint"
        },
        "destination": {
          "$ref": "#/$defs/destinationEndpoint"
        }
      }
    },
    "layout": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "direction"
          ],
          "properties": {
            "mode": {
              "const": "network_editor"
            },
            "direction": {
              "type": "string",
              "enum": [
                "left_to_right",
                "top_to_bottom"
              ]
            }
          }
        }
      ]
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "context",
        "target",
        "nodes",
        "connections",
        "layout"
      ],
      "properties": {
        "schema_version": {
          "const": "0.1.0"
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "root",
            "children"
          ],
          "properties": {
            "root": {
              "const": "Object"
            },
            "children": {
              "const": "Sop"
            }
          }
        },
        "target": {
          "$ref": "#/$defs/graphTarget"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/graphNode"
          }
        },
        "connections": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/connection"
          }
        },
        "layout": {
          "$ref": "#/$defs/layout"
        }
      }
    }
  }
}
