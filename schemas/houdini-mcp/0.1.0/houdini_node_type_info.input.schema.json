{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hia:houdini-mcp:0.1.0:houdini_node_type_info:input",
  "title": "houdini_node_type_info input",
  "description": "Read live parameter schemas for a bounded deny-by-default set of Object and SOP node types. Live Houdini metadata is authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "thread_id",
    "turn_id",
    "hip_session_id",
    "base_scene_revision",
    "idempotency_key",
    "deadline_ms",
    "permission_level",
    "node_types"
  ],
  "properties": {
    "request_id": { "$ref": "#/$defs/identifier" },
    "thread_id": { "$ref": "#/$defs/identifier" },
    "turn_id": { "$ref": "#/$defs/identifier" },
    "hip_session_id": { "$ref": "#/$defs/identifier" },
    "base_scene_revision": { "$ref": "#/$defs/sceneRevision" },
    "idempotency_key": { "$ref": "#/$defs/idempotencyKey" },
    "deadline_ms": { "$ref": "#/$defs/deadlineMs" },
    "permission_level": { "const": "scene_read" },
    "node_types": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nodeType" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{15,127}$"
    },
    "sceneRevision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "deadlineMs": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    },
    "nodeType": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["context", "name"],
          "properties": {
            "context": { "const": "Object" },
            "name": { "const": "geo" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["context", "name"],
          "properties": {
            "context": { "const": "Sop" },
            "name": {
              "type": "string",
              "enum": ["box", "transform", "merge", "null"]
            }
          }
        }
      ]
    }
  }
}
