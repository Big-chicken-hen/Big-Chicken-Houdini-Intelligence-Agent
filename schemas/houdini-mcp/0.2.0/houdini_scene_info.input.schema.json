{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hia:houdini-mcp:0.2.0:houdini_scene_info:input",
  "title": "houdini_scene_info input",
  "description": "Bounded read request for the current attested Houdini session and HIA-owned graph summaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "thread_id",
    "turn_id",
    "hip_session_id",
    "base_scene_revision",
    "idempotency_key",
    "deadline_ms",
    "permission_level",
    "include_graph_summaries"
  ],
  "properties": {
    "request_id": { "$ref": "#/$defs/identifier" },
    "thread_id": { "$ref": "#/$defs/identifier" },
    "turn_id": { "$ref": "#/$defs/identifier" },
    "hip_session_id": { "$ref": "#/$defs/identifier" },
    "base_scene_revision": { "$ref": "#/$defs/sceneRevision" },
    "idempotency_key": { "$ref": "#/$defs/idempotencyKey" },
    "deadline_ms": { "$ref": "#/$defs/deadlineMs" },
    "permission_level": { "const": "scene_read" },
    "include_graph_summaries": { "type": "boolean" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{15,127}$"
    },
    "sceneRevision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "deadlineMs": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    }
  }
}
