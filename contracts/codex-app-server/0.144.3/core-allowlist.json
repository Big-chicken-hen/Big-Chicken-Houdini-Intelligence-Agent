  "explicit_exclusions": {
    "experimental": {
      "reason": "Experimental protocol surfaces are outside the stable P0-C2B core.",
      "methods": [
        "experimentalFeature/list",
        "experimentalFeature/enablement/set",
        "item/tool/requestUserInput",
        "item/plan/delta"
      ],
      "schema_flags": [
        "--experimental"
      ]
    },
    "dynamicTools": {
      "reason": "Dynamic tool dispatch is not a core dependency.",
      "methods": [
        "item/tool/call"
      ]
    },
    "processApi": {
      "reason": "Process and command execution APIs are not part of the bridge core.",
      "methods": [
        "command/exec",
        "command/exec/write",
        "command/exec/terminate",
        "command/exec/resize",
        "command/exec/outputDelta",
        "process/outputDelta",
        "process/exited"
      ]
    },
    "threadShellCommand": {
      "reason": "Thread shell command execution is explicitly excluded.",
      "methods": [
        "thread/shellCommand"
      ]
    },
    "webSocket": {
      "reason": "The bridge-to-app-server transport is pinned to stdio JSONL.",
      "transports": [
        "websocket",
        "ws",
        "wss"
      ]
    }
  },
  "compatibility": {
    "unknown_methods": "reject",
    "unknown_notifications": "log-and-ignore-with-metric",
    "missing_allowlisted_method": "block-upgrade",
    "changed_allowlisted_schema": "block-upgrade-pending-review",
    "additive_optional_fields": "compatible-after-contract-tests",
    "additive_non_allowlisted_methods": "ignored"
  }
