<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="LauncherWindow"
    Title="Big-Chicken Launcher"
    Width="1120"
    Height="800"
    MinWidth="640"
    MinHeight="360"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#0B0D18"
    Foreground="#EDF1FF"
    FontFamily="Segoe UI"
    FontSize="13"
    Language="zh-CN"
    KeyboardNavigation.TabNavigation="Cycle"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#080C14" />
        <SolidColorBrush x:Key="CardBrush" Color="#111722" />
        <SolidColorBrush x:Key="CardRaisedBrush" Color="#161D2A" />
        <SolidColorBrush x:Key="BorderBrush" Color="#344157" />
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#242E3F" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F4FA" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B5BED0" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#7E8A9F" />
        <SolidColorBrush x:Key="PickerBackgroundBrush" Color="#0D1420" />
        <SolidColorBrush x:Key="PickerPopupBrush" Color="#0B111C" />
        <SolidColorBrush x:Key="PickerTextBrush" Color="#F4F7FF" />
        <SolidColorBrush x:Key="PickerSecondaryTextBrush" Color="#B8C3E0" />
        <SolidColorBrush x:Key="PickerDisabledTextBrush" Color="#95A0C2" />
        <SolidColorBrush x:Key="PickerDisabledBackgroundBrush" Color="#101420" />
        <SolidColorBrush x:Key="PickerHoverBrush" Color="#1B2A40" />
        <SolidColorBrush x:Key="PickerSelectedBrush" Color="#3A281B" />
        <SolidColorBrush x:Key="PickerBorderBrush" Color="#44536B" />
        <SolidColorBrush x:Key="PickerFocusBrush" Color="#F49A45" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#8D79E8" />
        <SolidColorBrush x:Key="AccentCyanBrush" Color="#66D7DF" />
        <SolidColorBrush x:Key="HoudiniOrangeBrush" Color="#F28C32" />
        <SolidColorBrush x:Key="HoudiniOrangeHoverBrush" Color="#FFA24E" />
        <SolidColorBrush x:Key="StatusGreenBrush" Color="#62C991" />
        <SolidColorBrush x:Key="StatusYellowBrush" Color="#E7B45E" />
        <SolidColorBrush x:Key="StatusRedBrush" Color="#E97982" />
        <SolidColorBrush x:Key="StatusNeutralBrush" Color="#8491A8" />
        <SolidColorBrush x:Key="GreenSurfaceBrush" Color="#172824" />
        <SolidColorBrush x:Key="YellowSurfaceBrush" Color="#2D261B" />
        <SolidColorBrush x:Key="RedSurfaceBrush" Color="#2E1C23" />
        <SolidColorBrush x:Key="NeutralSurfaceBrush" Color="#192130" />

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F6A34D" Offset="0" />
            <GradientStop Color="#E97727" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#141B2A" Offset="0" />
            <GradientStop Color="#171A32" Offset="0.55" />
            <GradientStop Color="#10252B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#131A26" Offset="0" />
            <GradientStop Color="#0F151F" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="15" />
        </Style>

        <Style x:Key="PickerChromeStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="DarkPickerComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource PickerTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PickerBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            x:Name="ItemChrome"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PickerHoverBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PickerFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PickerSelectedBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource HoudiniOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PickerFocusBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PickerDisabledTextBrush}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PickerDisabledBackgroundBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#2B3147" />
                                <Setter TargetName="ItemChrome" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkPickerComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource PickerTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PickerBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PickerBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7,44,7" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkPickerComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="PickerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                                <Grid>
                                    <ContentPresenter
                                        x:Name="SelectionPresenter"
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        IsHitTestVisible="False"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        SnapsToDevicePixels="True" />
                                    <ToggleButton
                                        x:Name="DropDownToggle"
                                        Width="38"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ClickMode="Press"
                                        Focusable="False"
                                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsTabStop="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" CornerRadius="0,9,9,0">
                                                    <Path
                                                        x:Name="DropDownArrow"
                                                        Width="10"
                                                        Height="6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Data="M 0,0 L 5,5 L 10,0 Z"
                                                        Fill="{StaticResource PickerSecondaryTextBrush}"
                                                        Stretch="Fill" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DropDownArrow" Property="Fill" Value="{StaticResource PickerFocusBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="DropDownArrow" Property="Fill" Value="{StaticResource PickerDisabledTextBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="False"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                StaysOpen="False">
                                <Grid
                                    MinWidth="{Binding PlacementTarget.ActualWidth, ElementName=PART_Popup}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border
                                        x:Name="PopupChrome"
                                        Padding="6"
                                        Background="{StaticResource PickerPopupBrush}"
                                        BorderBrush="{StaticResource PickerBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="9">
                                        <ScrollViewer
                                            CanContentScroll="True"
                                            HorizontalScrollBarVisibility="Disabled"
                                            VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter
                                                KeyboardNavigation.DirectionalNavigation="Contained"
                                                SnapsToDevicePixels="True" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PickerBorder" Property="Background" Value="#18223B" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="#7586BC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{StaticResource PickerFocusBrush}" />
                                <Setter TargetName="PickerBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="PickerBorder" Property="Background" Value="#2A211A" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{StaticResource HoudiniOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PickerDisabledTextBrush}" />
                                <Setter TargetName="PickerBorder" Property="Background" Value="{StaticResource PickerDisabledBackgroundBrush}" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="#2B3147" />
                                <Setter TargetName="SelectionPresenter" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="HoudiniPickerItemTemplate">
            <Grid ToolTip="{Binding path}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Foreground="{StaticResource PickerTextBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="{Binding version, StringFormat=Houdini {0}}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,0"
                    Foreground="{StaticResource PickerSecondaryTextBrush}"
                    FontSize="11"
                    Text="{Binding path}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BridgePickerItemTemplate">
            <Grid ToolTip="{Binding path}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Foreground="{StaticResource PickerTextBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="{Binding source, StringFormat=Bridge Python · {0}}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,0"
                    Foreground="{StaticResource PickerSecondaryTextBrush}"
                    FontSize="11"
                    Text="{Binding path}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BackendPickerItemTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Foreground="{StaticResource PickerTextBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="{Binding display}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,0"
                    Foreground="{StaticResource PickerSecondaryTextBrush}"
                    FontSize="11"
                    Text="{Binding id, StringFormat=backend · {0}}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#20263A" />
            <Setter Property="BorderBrush" Value="#46506F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonChrome"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#7080B5" />
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="#FFB66D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,11" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.94" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CountCardStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <DataTemplate x:Key="CheckResultTemplate">
            <Border
                Padding="8,7,2,7"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="2,0,0,0">
                <Expander
                    Background="Transparent"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    HorizontalContentAlignment="Stretch"
                    IsExpanded="False">
                    <Expander.Header>
                        <Grid Margin="0,1,5,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Width="8"
                                Height="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Fill="{Binding StatusBrush}"
                                Focusable="False"
                                IsHitTestVisible="False" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="0,0,12,0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontWeight="SemiBold"
                                Text="{Binding CheckName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{Binding StatusBrush}"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Text="{Binding StatusText}" />
                        </Grid>
                    </Expander.Header>
                    <StackPanel Margin="18,7,8,5">
                        <TextBlock
                            Foreground="{StaticResource TextSecondaryBrush}"
                            LineHeight="18"
                            Text="{Binding ResultText}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,5,0,0"
                            Foreground="{Binding AdviceBrush}"
                            LineHeight="18"
                            Text="{Binding AdviceText}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        PanningMode="VerticalOnly"
        VerticalScrollBarVisibility="Auto">
    <Grid
        x:Name="LayoutRoot"
        MinHeight="{Binding RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}, Path=ViewportHeight}"
        Background="{StaticResource PageBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="20,18,8,12"
            Padding="0,2"
            Background="Transparent"
            BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="3"
                    Height="42"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{StaticResource HoudiniOrangeBrush}"
                    CornerRadius="2" />
                <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="BrandTitleText"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Big-Chicken Houdini Intelligence Agent" />
                    <TextBlock
                        x:Name="BrandSubtitleText"
                        Margin="0,5,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="12"
                        Text="检查 Houdini、Bridge、Codex 与 MCP 的启动环境"
                        TextWrapping="Wrap" />
                </StackPanel>
                <Border
                    Grid.Column="2"
                    Padding="9,5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#111A27"
                    BorderBrush="{StaticResource BorderSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="7">
                    <TextBlock
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Text="LOCAL · LOOPBACK" />
                </Border>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Margin="20,0,8,10"
            Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="98" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="78" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,11">
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Text="环境配置" />
                    <TextBlock Margin="0,2,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Text="多版本必须明确选择；变更后重新检查。" />
                </StackPanel>

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="MCP backend" />
                <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Style="{StaticResource PickerChromeStyle}">
                    <ComboBox
                        x:Name="McpBackendComboBox"
                        AutomationProperties.Name="MCP backend"
                        IsEditable="False"
                        ItemTemplate="{StaticResource BackendPickerItemTemplate}"
                        Style="{StaticResource DarkPickerComboBoxStyle}"
                        TabIndex="2" />
                </Border>

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="Houdini 版本" />
                <Border Grid.Row="2" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource PickerChromeStyle}">
                    <ComboBox
                        x:Name="HoudiniComboBox"
                        AutomationProperties.Name="Houdini 版本"
                        IsEditable="False"
                        ItemTemplate="{StaticResource HoudiniPickerItemTemplate}"
                        Style="{StaticResource DarkPickerComboBoxStyle}"
                        TabIndex="3" />
                </Border>
                <Button
                    x:Name="BrowseHoudiniButton"
                    Grid.Row="2"
                    Grid.Column="2"
                    AutomationProperties.Name="浏览 houdini.exe"
                    Content="浏览…"
                    Style="{StaticResource CompactButtonStyle}"
                    TabIndex="4" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    x:Name="HoudiniPathText"
                    Margin="3,4,0,9"
                    Foreground="{StaticResource TextMutedBrush}"
                    FontSize="11"
                    Text="尚未选择 houdini.exe"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="尚未选择 houdini.exe" />

                <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="Bridge Python" />
                <Border Grid.Row="4" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource PickerChromeStyle}">
                    <ComboBox
                        x:Name="BridgePythonComboBox"
                        AutomationProperties.Name="Bridge Python"
                        IsEditable="False"
                        ItemTemplate="{StaticResource BridgePickerItemTemplate}"
                        Style="{StaticResource DarkPickerComboBoxStyle}"
                        TabIndex="5" />
                </Border>
                <Button
                    x:Name="BrowseBridgeButton"
                    Grid.Row="4"
                    Grid.Column="2"
                    AutomationProperties.Name="浏览 Bridge python.exe"
                    Content="浏览…"
                    Style="{StaticResource CompactButtonStyle}"
                    TabIndex="6" />

                <TextBlock
                    Grid.Row="5"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    x:Name="BridgePathText"
                    Margin="3,4,0,0"
                    Foreground="{StaticResource TextMutedBrush}"
                    FontSize="11"
                    Text="尚未选择 Bridge python.exe"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="尚未选择 Bridge python.exe" />

                <TextBlock
                    Grid.Row="6"
                    Margin="0,4,0,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="最终输出" />
                <Border
                    Grid.Row="6"
                    Grid.Column="1"
                    Margin="0,4,8,0"
                    Background="{StaticResource PickerBackgroundBrush}"
                    BorderBrush="{StaticResource PickerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                    <TextBox
                        x:Name="RenderOutputTextBox"
                        Padding="11,8"
                        AutomationProperties.Name="最终渲染输出目录"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="{StaticResource AccentCyanBrush}"
                        Foreground="{StaticResource PickerTextBrush}"
                        TabIndex="7"
                        ToolTip="留空时使用项目 .runtime/cache"
                        VerticalContentAlignment="Center" />
                </Border>
                <Button
                    x:Name="BrowseRenderOutputButton"
                    Grid.Row="6"
                    Grid.Column="2"
                    Margin="0,4,0,0"
                    AutomationProperties.Name="选择最终渲染输出目录"
                    Content="选择…"
                    Style="{StaticResource CompactButtonStyle}"
                    TabIndex="8" />
                <TextBlock
                    Grid.Row="7"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="3,5,0,0"
                    Foreground="{StaticResource TextMutedBrush}"
                    FontSize="11"
                    Text="最终 EXR、图片、视频、USD、导出和模拟缓存可放在这里；留空时使用项目 .runtime/cache。它与内部截图、预览和临时缓存目录不同。"
                    TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border
            x:Name="RecoveryCard"
            Grid.Row="2"
            Grid.Column="0"
            Margin="20,0,8,10"
            Padding="14,11"
            Background="{StaticResource YellowSurfaceBrush}"
            BorderBrush="{StaticResource StatusYellowBrush}"
            BorderThickness="1"
            CornerRadius="13"
            Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="检测到可恢复副本" />
                    <TextBlock
                        Margin="0,3,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="上次 Houdini 未正常结束。恢复会在新 session 中打开 checkpoint 副本，绝不覆盖原 HIP。"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="RecoveryCheckpointText"
                        Margin="0,4,0,0"
                        Foreground="{StaticResource PickerSecondaryTextBrush}"
                        FontSize="11"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <WrapPanel Grid.Row="1" Margin="0,9,0,0">
                    <RadioButton
                        x:Name="RecoverCheckpointOption"
                        AutomationProperties.Name="恢复副本"
                        Content="恢复副本（推荐）"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        GroupName="RecoveryChoice"
                        IsChecked="True"
                        TabIndex="0" />
                    <RadioButton
                        x:Name="NormalLaunchOption"
                        Margin="18,0,0,0"
                        AutomationProperties.Name="正常启动"
                        Content="正常启动"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        GroupName="RecoveryChoice"
                        TabIndex="1" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Grid.Column="0" Margin="20,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Text="自检状态" />
                <TextBlock Margin="0,2,16,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Text="颜色与文字共同标识" />
            </StackPanel>
            <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Style="{StaticResource CountCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center" Fill="{StaticResource StatusGreenBrush}" />
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="通过 " />
                        <TextBlock x:Name="PassCountText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" Text="0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CountCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center" Fill="{StaticResource StatusYellowBrush}" />
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="警告 " />
                        <TextBlock x:Name="WarningCountText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" Text="0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CountCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center" Fill="{StaticResource StatusRedBrush}" />
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="阻断 " />
                        <TextBlock x:Name="BlockedCountText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" Text="0" />
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Grid>

        <Border
            Grid.Row="4"
            Grid.Column="0"
            Height="216"
            Margin="20,0,8,8"
            Padding="12,11,7,5"
            Background="#0F151F"
            BorderBrush="{StaticResource BorderSoftBrush}"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Margin="2,0,0,8"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="问题与检查结果" />
                <Border
                    x:Name="EmptyStateBorder"
                    Grid.Row="1"
                    Margin="0,8,5,8"
                    Padding="14"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="#121B28"
                    BorderThickness="0"
                    CornerRadius="8">
                    <TextBlock
                        x:Name="EmptyStateText"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="等待首次检查…"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </Border>
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,0,4,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl
                        x:Name="ChecksListBox"
                        AutomationProperties.Name="自检结果"
                        ItemTemplate="{StaticResource CheckResultTemplate}" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="5" Grid.Column="0" Margin="20,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border
                x:Name="BusyPanel"
                Grid.Row="0"
                Padding="13,10"
                Background="{StaticResource NeutralSurfaceBrush}"
                BorderBrush="#4B5B91"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Text="正在扫描并检查环境…" />
                    <ProgressBar
                        x:Name="BusyProgressBar"
                        Grid.Column="1"
                        Height="5"
                        Margin="15,0,2,0"
                        VerticalAlignment="Center"
                        Background="#252B40"
                        Foreground="{StaticResource AccentCyanBrush}"
                        IsIndeterminate="True" />
                </Grid>
            </Border>
            <Border
                x:Name="InlineStatusBorder"
                Grid.Row="1"
                Margin="0,8,0,0"
                Padding="13,9"
                Background="{StaticResource NeutralSurfaceBrush}"
                BorderBrush="{StaticResource StatusNeutralBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="InlineStatusText"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Border
            Grid.Row="6"
            Grid.Column="0"
            Margin="20,0,8,18"
            Padding="13"
            Background="#101722"
            BorderBrush="{StaticResource BorderSoftBrush}"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Text="报告路径" />
                    <Border Grid.Column="1" Background="#0D101A" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="7">
                        <TextBox
                            x:Name="ReportPathTextBox"
                            Padding="9,6"
                            AutomationProperties.Name="最新自检报告路径"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{StaticResource AccentCyanBrush}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            IsReadOnly="True"
                            TabIndex="9"
                            Text="尚未生成报告"
                            TextWrapping="NoWrap"
                            ToolTip="尚未生成报告" />
                    </Border>
                </Grid>
                <WrapPanel Grid.Row="2" Margin="0,0,0,-8" VerticalAlignment="Top">
                        <Button
                            x:Name="RescanButton"
                            Margin="0,0,10,8"
                            AutomationProperties.Name="重新扫描"
                            Content="重新扫描"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="10" />
                        <Button
                            x:Name="RepairButton"
                            Margin="0,0,10,8"
                            AutomationProperties.Name="修复安全项目"
                            Content="修复安全项目"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="11" />
                        <Button
                            x:Name="CleanupScreenshotsButton"
                            Margin="0,0,10,8"
                            AutomationProperties.Name="清理截图缓存"
                            Content="清理截图缓存"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="12"
                            ToolTip="只清理项目 .runtime\cache\screenshots 第一层的 Big-Chicken PNG 截图" />
                        <Button
                            x:Name="CopyReportButton"
                            Margin="0,0,10,8"
                            AutomationProperties.Name="复制报告路径"
                            Content="复制报告路径"
                            IsEnabled="False"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="13" />
                </WrapPanel>
                <Button
                    x:Name="LaunchButton"
                    Grid.Row="4"
                    MinWidth="196"
                    HorizontalAlignment="Right"
                    AutomationProperties.Name="启动 Houdini"
                    Content="启动 Houdini  ✦"
                    IsDefault="True"
                    IsEnabled="False"
                    Style="{StaticResource PrimaryButtonStyle}"
                    TabIndex="14" />
            </Grid>
        </Border>

        <Border
            x:Name="RightVisualRail"
            Grid.Row="0"
            Grid.RowSpan="8"
            Grid.Column="2"
            Margin="8,18,20,18"
            Padding="18"
            Background="{StaticResource HeaderGradientBrush}"
            BorderBrush="#2E3A50"
            BorderThickness="1"
            CornerRadius="16"
            ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock
                        Foreground="{StaticResource AccentCyanBrush}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Text="CREATIVE SYSTEM · LOCAL" />
                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="创作环境总览" />
                    <TextBlock
                        Margin="0,5,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        LineHeight="19"
                        Text="从一处确认版本、运行环境与恢复副本，再进入 Houdini。"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    x:Name="OverallStatusBadge"
                    Grid.Row="2"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource NeutralSurfaceBrush}"
                    BorderBrush="{StaticResource StatusNeutralBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse
                            x:Name="OverallStatusDot"
                            Width="9"
                            Height="9"
                            Margin="0,0,9,0"
                            VerticalAlignment="Center"
                            Fill="{StaticResource StatusNeutralBrush}" />
                        <TextBlock
                            x:Name="OverallStatusText"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            FontWeight="SemiBold"
                            Text="等待检查" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="10"
                            Text="PREFLIGHT" />
                    </Grid>
                </Border>

                <Grid Grid.Row="4" Height="230" ClipToBounds="True">
                    <Border
                        Background="#0D1723"
                        BorderBrush="#35445C"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid ClipToBounds="True">
                            <Path
                                Margin="28"
                                Data="M 0,150 L 78,104 L 136,126 L 220,58 L 310,92"
                                Stroke="#27455D"
                                StrokeThickness="1"
                                Stretch="Fill" />
                            <Ellipse Width="7" Height="7" Margin="44,62,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#456A87" />
                            <Ellipse Width="5" Height="5" Margin="0,0,58,52" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#7B6BB4" />
                            <TextBlock
                                Margin="18"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="10"
                                Text="CREATIVE WORKSPACE" />
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="6">
                    <Border Height="1" Margin="0,0,0,13" Background="#334157" />
                    <TextBlock
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="11"
                        Text="自检与启动仅使用项目本地环境"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="10"
                        Text="127.0.0.1 · portable project root"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
