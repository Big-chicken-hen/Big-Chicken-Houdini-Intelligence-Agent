<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="LauncherWindow"
    Title="Big-Chicken Houdini Intelligence Agent"
    Width="1180"
    Height="820"
    MinWidth="640"
    MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#080B11"
    Foreground="#F4F7FB"
    FontFamily="Segoe UI"
    FontSize="13"
    Language="zh-CN"
    KeyboardNavigation.TabNavigation="Cycle"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <SolidColorBrush x:Key="CardRaisedBrush" Color="#171C2A" />
        <SolidColorBrush x:Key="BorderBrush" Color="#35405A" />
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#252C42" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F6FC" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#BCC3D6" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#858EA8" />
        <SolidColorBrush x:Key="PickerBackgroundBrush" Color="#0C1020" />
        <SolidColorBrush x:Key="PickerPopupBrush" Color="#0D1222" />
        <SolidColorBrush x:Key="PickerTextBrush" Color="#F7F9FC" />
        <SolidColorBrush x:Key="PickerSecondaryTextBrush" Color="#BBC7D8" />
        <SolidColorBrush x:Key="PickerDisabledTextBrush" Color="#9BA6B8" />
        <SolidColorBrush x:Key="PickerDisabledBackgroundBrush" Color="#11161E" />
        <SolidColorBrush x:Key="PickerHoverBrush" Color="#1D2942" />
        <SolidColorBrush x:Key="PickerSelectedBrush" Color="#26234B" />
        <SolidColorBrush x:Key="PickerBorderBrush" Color="#485576" />
        <SolidColorBrush x:Key="PickerFocusBrush" Color="#63D9DA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#9283FF" />
        <SolidColorBrush x:Key="AccentCyanBrush" Color="#5ADDD6" />
        <SolidColorBrush x:Key="AccentPinkBrush" Color="#F29BC2" />
        <SolidColorBrush x:Key="DisabledPrimaryBackgroundBrush" Color="#5B3D29" />
        <SolidColorBrush x:Key="DisabledPrimaryBorderBrush" Color="#9B765E" />
        <SolidColorBrush x:Key="DisabledPrimaryTextBrush" Color="#E1E5EC" />
        <SolidColorBrush x:Key="StatusGreenBrush" Color="#65D19A" />
        <SolidColorBrush x:Key="StatusYellowBrush" Color="#EFC06B" />
        <SolidColorBrush x:Key="StatusRedBrush" Color="#F07A86" />
        <SolidColorBrush x:Key="StatusNeutralBrush" Color="#8795A9" />
        <SolidColorBrush x:Key="GreenSurfaceBrush" Color="#142820" />
        <SolidColorBrush x:Key="YellowSurfaceBrush" Color="#2B2418" />
        <SolidColorBrush x:Key="RedSurfaceBrush" Color="#2B1920" />
        <SolidColorBrush x:Key="NeutralSurfaceBrush" Color="#171D2C" />
        <SolidColorBrush x:Key="RailLineBrush" Color="#394366" />

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFAD65" Offset="0" />
            <GradientStop Color="#F1782C" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#F7F4FF" Offset="0" />
            <GradientStop Color="#B9A8FF" Offset="0.55" />
            <GradientStop Color="#73E3DD" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="WorkspaceGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B0D1B" Offset="0" />
            <GradientStop Color="#0D1120" Offset="0.55" />
            <GradientStop Color="#09171B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#121625" Offset="0" />
            <GradientStop Color="#0E1420" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ModernThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border
                            x:Name="ScrollThumb"
                            Margin="2,1"
                            Background="#46546A"
                            CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScrollThumb" Property="Background" Value="#60718B" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ScrollThumb" Property="Background" Value="{StaticResource AccentCyanBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ScrollThumb" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton
                                        Command="{x:Static ScrollBar.PageUpCommand}"
                                        Focusable="False"
                                        IsTabStop="False"
                                        Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton
                                        Command="{x:Static ScrollBar.PageDownCommand}"
                                        Focusable="False"
                                        IsTabStop="False"
                                        Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="PanningMode" Value="VerticalOnly" />
        </Style>

        <Style x:Key="PickerChromeStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="DarkPickerComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource PickerTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PickerBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            x:Name="ItemChrome"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PickerHoverBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PickerFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PickerSelectedBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PickerFocusBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PickerDisabledTextBrush}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PickerDisabledBackgroundBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#2B3147" />
                                <Setter TargetName="ItemChrome" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkPickerComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource PickerTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PickerBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PickerBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7,44,7" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkPickerComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="PickerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                                <Grid>
                                    <ContentPresenter
                                        x:Name="SelectionPresenter"
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        IsHitTestVisible="False"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        SnapsToDevicePixels="True" />
                                    <ToggleButton
                                        x:Name="DropDownToggle"
                                        Width="38"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ClickMode="Press"
                                        Focusable="False"
                                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsTabStop="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" CornerRadius="0,9,9,0">
                                                    <Path
                                                        x:Name="DropDownArrow"
                                                        Width="10"
                                                        Height="6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Data="M 0,0 L 5,5 L 10,0 Z"
                                                        Fill="{StaticResource PickerSecondaryTextBrush}"
                                                        Stretch="Fill" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DropDownArrow" Property="Fill" Value="{StaticResource PickerFocusBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="DropDownArrow" Property="Fill" Value="{StaticResource PickerDisabledTextBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="False"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                StaysOpen="False">
                                <Grid
                                    MinWidth="{Binding PlacementTarget.ActualWidth, ElementName=PART_Popup}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border
                                        x:Name="PopupChrome"
                                        Padding="6"
                                        Background="{StaticResource PickerPopupBrush}"
                                        BorderBrush="{StaticResource PickerBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="9">
                                        <ScrollViewer
                                            Style="{StaticResource ModernScrollViewerStyle}"
                                            CanContentScroll="True"
                                            HorizontalScrollBarVisibility="Disabled"
                                            VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter
                                                KeyboardNavigation.DirectionalNavigation="Contained"
                                                SnapsToDevicePixels="True" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PickerBorder" Property="Background" Value="#18223B" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="#7586BC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{StaticResource PickerFocusBrush}" />
                                <Setter TargetName="PickerBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="PickerBorder" Property="Background" Value="#18172F" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PickerDisabledTextBrush}" />
                                <Setter TargetName="PickerBorder" Property="Background" Value="{StaticResource PickerDisabledBackgroundBrush}" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="#2B3147" />
                                <Setter TargetName="SelectionPresenter" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="HoudiniPickerItemTemplate">
            <Grid ToolTip="{Binding path}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Foreground="{StaticResource PickerTextBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="{Binding version, StringFormat=Houdini {0}}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,0"
                    Foreground="{StaticResource PickerSecondaryTextBrush}"
                    FontSize="11"
                    Text="{Binding path}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BridgePickerItemTemplate">
            <Grid ToolTip="{Binding path}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Foreground="{StaticResource PickerTextBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="{Binding source, StringFormat=Bridge Python · {0}}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,0"
                    Foreground="{StaticResource PickerSecondaryTextBrush}"
                    FontSize="11"
                    Text="{Binding path}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BackendPickerItemTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Foreground="{StaticResource PickerTextBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="{Binding display}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,0"
                    Foreground="{StaticResource PickerSecondaryTextBrush}"
                    FontSize="11"
                    Text="{Binding id, StringFormat=backend · {0}}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource CardRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonChrome"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#64758F" />
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#121722" />
                    <Setter Property="BorderBrush" Value="#3F485C" />
                    <Setter Property="Foreground" Value="#8F99AD" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="#FFC088" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="26,12" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="14" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.94" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledPrimaryBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DisabledPrimaryBorderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource DisabledPrimaryTextBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CountCardStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="14,0,0,0" />
        </Style>

        <DataTemplate x:Key="CheckResultTemplate">
            <Border
                Padding="8,7,2,7"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="2,0,0,0">
                <Expander
                    Background="Transparent"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    HorizontalContentAlignment="Stretch"
                    IsExpanded="False">
                    <Expander.Header>
                        <Grid Margin="0,1,5,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Width="8"
                                Height="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Fill="{Binding StatusBrush}"
                                Focusable="False"
                                IsHitTestVisible="False" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="0,0,12,0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontWeight="SemiBold"
                                Text="{Binding CheckName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{Binding StatusBrush}"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Text="{Binding StatusText}" />
                        </Grid>
                    </Expander.Header>
                    <StackPanel Margin="18,7,8,5">
                        <TextBlock
                            Foreground="{StaticResource TextSecondaryBrush}"
                            LineHeight="18"
                            Text="{Binding ResultText}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,5,0,0"
                            Foreground="{Binding AdviceBrush}"
                            LineHeight="18"
                            Text="{Binding AdviceText}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid
        x:Name="LayoutRoot"
        Background="{StaticResource WorkspaceGradientBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Grid.Column="0"
            MaxWidth="1120"
            Margin="28,16,28,12"
            Padding="0"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <Viewbox
                    x:Name="BrandNodeMotif"
                    Width="34"
                    Height="44"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Stretch="Uniform"
                    IsHitTestVisible="False">
                    <Canvas Width="34" Height="44">
                        <Path
                            Data="M 5,8 L 17,8 L 17,22 L 29,22 L 29,36"
                            Stroke="{StaticResource RailLineBrush}"
                            StrokeThickness="2" />
                        <Ellipse Canvas.Left="1" Canvas.Top="4" Width="8" Height="8" Fill="{StaticResource AccentPinkBrush}" />
                        <Ellipse Canvas.Left="13" Canvas.Top="18" Width="8" Height="8" Fill="{StaticResource AccentPurpleBrush}" />
                        <Ellipse Canvas.Left="25" Canvas.Top="32" Width="8" Height="8" Fill="{StaticResource AccentCyanBrush}" />
                    </Canvas>
                </Viewbox>
                <StackPanel
                    Grid.Column="1"
                    Margin="13,0,16,0"
                    AutomationProperties.Name="Big-Chicken Houdini Intelligence Agent"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="BrandTitleText"
                        Foreground="{StaticResource BrandGradientBrush}"
                        FontSize="27"
                        FontWeight="Bold"
                        Text="BIG-CHICKEN" />
                    <TextBlock
                        x:Name="BrandSubtitleText"
                        Margin="1,2,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="Houdini Intelligence Agent" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="28,0"
            Background="{StaticResource BorderSoftBrush}" />

        <ScrollViewer
            x:Name="MainScrollViewer"
            Grid.Row="2"
            Style="{StaticResource ModernScrollViewerStyle}">
            <Border
                x:Name="MainWorkspacePanel"
                MaxWidth="1060"
                Margin="28,14,28,16"
                HorizontalAlignment="Stretch"
                Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="22,18,22,16"
            Padding="0"
            Background="Transparent"
            BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="106" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="76" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,13">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource AccentCyanBrush}" FontSize="10" FontWeight="SemiBold" Text="ENVIRONMENT" />
                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Text="启动环境" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="11"
                        Text="选择变更后需重新检查" />
                </Grid>

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Text="MCP backend" />
                <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,9" Style="{StaticResource PickerChromeStyle}">
                    <ComboBox
                        x:Name="McpBackendComboBox"
                        AutomationProperties.Name="MCP backend"
                        IsEditable="False"
                        ItemTemplate="{StaticResource BackendPickerItemTemplate}"
                        Style="{StaticResource DarkPickerComboBoxStyle}"
                        TabIndex="2" />
                </Border>

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Text="Houdini 版本" />
                <Border Grid.Row="2" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource PickerChromeStyle}">
                    <ComboBox
                        x:Name="HoudiniComboBox"
                        AutomationProperties.Name="Houdini 版本"
                        IsEditable="False"
                        ItemTemplate="{StaticResource HoudiniPickerItemTemplate}"
                        Style="{StaticResource DarkPickerComboBoxStyle}"
                        TabIndex="3" />
                </Border>
                <Button
                    x:Name="BrowseHoudiniButton"
                    Grid.Row="2"
                    Grid.Column="2"
                    AutomationProperties.Name="浏览 houdini.exe"
                    Content="浏览…"
                    Style="{StaticResource CompactButtonStyle}"
                    TabIndex="4" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    x:Name="HoudiniPathText"
                    Margin="3,4,0,8"
                    Foreground="{StaticResource TextMutedBrush}"
                    FontSize="11"
                    Text="尚未选择 houdini.exe"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="尚未选择 houdini.exe"
                    Visibility="Collapsed" />

                <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Text="Bridge Python" />
                <Border Grid.Row="4" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource PickerChromeStyle}">
                    <ComboBox
                        x:Name="BridgePythonComboBox"
                        AutomationProperties.Name="Bridge Python"
                        IsEditable="False"
                        ItemTemplate="{StaticResource BridgePickerItemTemplate}"
                        Style="{StaticResource DarkPickerComboBoxStyle}"
                        TabIndex="5" />
                </Border>
                <Button
                    x:Name="BrowseBridgeButton"
                    Grid.Row="4"
                    Grid.Column="2"
                    AutomationProperties.Name="浏览 Bridge python.exe"
                    Content="浏览…"
                    Style="{StaticResource CompactButtonStyle}"
                    TabIndex="6" />

                <TextBlock
                    Grid.Row="5"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    x:Name="BridgePathText"
                    Margin="3,4,0,0"
                    Foreground="{StaticResource TextMutedBrush}"
                    FontSize="11"
                    Text="尚未选择 Bridge python.exe"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="尚未选择 Bridge python.exe"
                    Visibility="Collapsed" />

                <TextBlock
                    Grid.Row="6"
                    Margin="0,4,0,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="输出目录" />
                <Border
                    Grid.Row="6"
                    Grid.Column="1"
                    Margin="0,4,8,0"
                    Background="{StaticResource PickerBackgroundBrush}"
                    BorderBrush="{StaticResource PickerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                    <TextBox
                        x:Name="RenderOutputTextBox"
                        Padding="11,8"
                        AutomationProperties.Name="最终渲染输出目录"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="{StaticResource AccentCyanBrush}"
                        Foreground="{StaticResource PickerTextBrush}"
                        TabIndex="7"
                        ToolTip="留空时使用项目 .runtime/cache"
                        VerticalContentAlignment="Center" />
                </Border>
                <Button
                    x:Name="BrowseRenderOutputButton"
                    Grid.Row="6"
                    Grid.Column="2"
                    Margin="0,4,0,0"
                    AutomationProperties.Name="选择最终渲染输出目录"
                    Content="选择…"
                    Style="{StaticResource CompactButtonStyle}"
                    TabIndex="8" />
                <TextBlock
                    Grid.Row="7"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="3,5,0,0"
                    Foreground="{StaticResource TextMutedBrush}"
                    FontSize="11"
                    Text="最终 EXR、图片、视频、USD、导出和模拟缓存；留空使用项目 .runtime/cache。它与内部截图、预览和临时缓存目录不同。"
                    TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="22,0"
            Background="{StaticResource BorderSoftBrush}" />

        <Border
            x:Name="RecoveryCard"
            Grid.Row="2"
            Margin="22,14,22,0"
            Padding="14,11"
            Background="{StaticResource YellowSurfaceBrush}"
            BorderBrush="{StaticResource StatusYellowBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="检测到可恢复副本" />
                    <TextBlock
                        Margin="0,3,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="上次 Houdini 未正常结束。恢复会在新 session 中打开 checkpoint 副本，绝不覆盖原 HIP。"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="RecoveryCheckpointText"
                        Margin="0,4,0,0"
                        Foreground="{StaticResource PickerSecondaryTextBrush}"
                        FontSize="11"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <WrapPanel Grid.Row="1" Margin="0,9,0,0">
                    <RadioButton
                        x:Name="RecoverCheckpointOption"
                        AutomationProperties.Name="恢复副本"
                        Content="恢复副本（推荐）"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        GroupName="RecoveryChoice"
                        IsChecked="True"
                        TabIndex="0" />
                    <RadioButton
                        x:Name="NormalLaunchOption"
                        Margin="18,0,0,0"
                        AutomationProperties.Name="正常启动"
                        Content="正常启动"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        GroupName="RecoveryChoice"
                        TabIndex="1" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="3"
            Margin="22,14,22,8"
            Padding="0"
            Background="Transparent"
            BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource AccentPinkBrush}" FontSize="10" FontWeight="SemiBold" Text="PREFLIGHT" />
                    <TextBlock Margin="10,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Text="自检状态" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource CountCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center" Fill="{StaticResource StatusGreenBrush}" />
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Text="通过 " />
                            <TextBlock x:Name="PassCountText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" Text="0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CountCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center" Fill="{StaticResource StatusYellowBrush}" />
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Text="警告 " />
                            <TextBlock x:Name="WarningCountText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" Text="0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CountCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center" Fill="{StaticResource StatusRedBrush}" />
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Text="阻断 " />
                            <TextBlock x:Name="BlockedCountText" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" Text="0" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="4"
            MinHeight="168"
            MaxHeight="246"
            Margin="22,0,16,10"
            Padding="0"
            Background="Transparent"
            BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="2,0,5,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Text="检查项" />
                    <TextBlock Grid.Column="1" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Text="展开查看结果与修复建议" />
                </Grid>
                <Border
                    x:Name="EmptyStateBorder"
                    Grid.Row="1"
                    Margin="0,8,5,8"
                    Padding="14"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="{StaticResource NeutralSurfaceBrush}"
                    BorderThickness="0"
                    CornerRadius="8">
                    <TextBlock
                        x:Name="EmptyStateText"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="等待首次检查…"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </Border>
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,0,4,0"
                    Style="{StaticResource ModernScrollViewerStyle}">
                    <ItemsControl
                        x:Name="ChecksListBox"
                        AutomationProperties.Name="自检结果"
                        ItemTemplate="{StaticResource CheckResultTemplate}" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="5" Margin="22,0,22,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border
                x:Name="BusyPanel"
                Grid.Row="0"
                Padding="13,10"
                Background="{StaticResource NeutralSurfaceBrush}"
                BorderBrush="#4B5B91"
                BorderThickness="1"
                CornerRadius="11"
                Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Text="正在扫描并检查环境…" />
                    <ProgressBar
                        x:Name="BusyProgressBar"
                        Grid.Column="1"
                        Height="5"
                        Margin="15,0,2,0"
                        VerticalAlignment="Center"
                        Background="#252B40"
                        Foreground="{StaticResource AccentCyanBrush}"
                        IsIndeterminate="True" />
                </Grid>
            </Border>
            <Border
                x:Name="InlineStatusBorder"
                Grid.Row="1"
                Margin="0,8,0,0"
                Padding="13,9"
                Background="{StaticResource NeutralSurfaceBrush}"
                BorderBrush="{StaticResource StatusNeutralBrush}"
                BorderThickness="1"
                CornerRadius="11"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="InlineStatusText"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    TextWrapping="Wrap" />
            </Border>
        </Grid>

                </Grid>
            </Border>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            Margin="0"
            Padding="28,10,28,14"
            Background="#0C101B"
            BorderBrush="{StaticResource BorderSoftBrush}"
            BorderThickness="0,1,0,0"
            CornerRadius="0">
            <Grid
                MaxWidth="1120"
                HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource AccentCyanBrush}" FontSize="10" FontWeight="SemiBold" Text="ACTIONS" />
                        <TextBlock Margin="10,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Text="报告与启动" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Text="红色阻断时无法启动" />
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Text="报告路径" />
                    <Border Grid.Column="1" Background="{StaticResource PickerBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="8">
                        <TextBox
                            x:Name="ReportPathTextBox"
                            Padding="9,6"
                            AutomationProperties.Name="最新自检报告路径"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{StaticResource AccentCyanBrush}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            IsReadOnly="True"
                            TabIndex="9"
                            Text="尚未生成报告"
                            TextWrapping="NoWrap"
                            ToolTip="尚未生成报告" />
                    </Border>
                </Grid>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <WrapPanel Margin="0,0,6,-8" VerticalAlignment="Top">
                        <Button
                            x:Name="RescanButton"
                            Margin="0,0,8,8"
                            AutomationProperties.Name="重新扫描"
                            Content="重新扫描"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="10" />
                        <Button
                            x:Name="RepairButton"
                            Margin="0,0,8,8"
                            AutomationProperties.Name="自动修复安全项"
                            Content="自动修复安全项"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="11" />
                        <Button
                            x:Name="CleanupScreenshotsButton"
                            Margin="0,0,8,8"
                            AutomationProperties.Name="清理截图缓存"
                            Content="清理截图缓存"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="12"
                            ToolTip="只清理项目 .runtime\cache\screenshots 第一层的 Big-Chicken PNG 截图" />
                        <Button
                            x:Name="CopyReportButton"
                            Margin="0,0,8,8"
                            AutomationProperties.Name="复制报告路径"
                            Content="复制报告路径"
                            IsEnabled="False"
                            Style="{StaticResource ActionButtonStyle}"
                            TabIndex="13" />
                    </WrapPanel>
                    <Button
                        x:Name="LaunchButton"
                        Grid.Column="1"
                        Margin="10,0,0,8"
                        MinWidth="190"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        AutomationProperties.Name="启动 Houdini"
                        Content="启动 Houdini"
                        IsDefault="True"
                        IsEnabled="False"
                        Style="{StaticResource PrimaryButtonStyle}"
                        TabIndex="14" />
                </Grid>
            </Grid>
        </Border>

        <Border
            x:Name="RightVisualRail"
            Grid.Row="0"
            Width="210"
            Margin="0,16,28,12"
            Padding="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0">
                <Border
                    x:Name="OverallStatusBadge"
                    Padding="12,8"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource NeutralSurfaceBrush}"
                    BorderBrush="{StaticResource StatusNeutralBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse
                            x:Name="OverallStatusDot"
                            Width="8"
                            Height="8"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Fill="{StaticResource StatusNeutralBrush}" />
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                x:Name="OverallStatusText"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontWeight="SemiBold"
                                Text="等待检查" />
                            <TextBlock
                                Margin="0,2,0,0"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="9"
                                Text="PREFLIGHT STATUS" />
                        </StackPanel>
                    </Grid>
                </Border>
        </Border>
    </Grid>
</Window>
